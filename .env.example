# AI-VulnAtlas Configuration

# LLM Provider: none | anthropic | openai | deepseek | custom
LLM_PROVIDER=deepseek

# DeepSeek API (推荐)
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/anthropic

# Anthropic API (可选)
# ANTHROPIC_API_KEY=
# ANTHROPIC_API_URL=https://api.anthropic.com

# OpenAI API (可选)
# OPENAI_API_KEY=
# OPENAI_API_URL=https://api.openai.com

# Custom API (可选，兼容 OpenAI 格式)
# CUSTOM_API_KEY=
# CUSTOM_API_URL=

# Model configuration
# deepseek-v4-pro: 更强但较慢
# deepseek-v4-flash: 更快但较弱
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=4096

# Other settings
MAX_WORKERS=1
