# 忽略大型二进制文件
*.zip
*.tar
*.gz
*.rar
*.7z

# 忽略Office临时文件
~$*

# 忽略操作系统生成的文件
.DS_Store
Thumbs.db

# 忽略编辑器临时文件
*.swp
*.swo
*~
.idea/
.vscode/

# 忽略Python相关文件（如果有的话）
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 忽略Node.js相关文件（如果有的话）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 忽略环境变量文件
.env
.env.local
.env.*.local

# 忽略GitHub令牌文件
.github_token

# 忽略Office文档
*.docx
*.doc
*.xlsx
*.xls

# 忽略data目录下的文件（保留目录结构）
data/*
!data/.gitkeep

# 忽略日志文件
*.log

# 忽略临时文件
*.tmp
*.temp

# 忽略克隆的仓库
repos/

# 忽略日志目录
logs/

# 忽略输出目录
output/

# 忽略状态目录
state/

# 忽略工作树目录
worktrees/

# 忽略Python缓存
__pycache__/
